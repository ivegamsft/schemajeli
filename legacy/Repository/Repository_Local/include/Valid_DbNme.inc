FUNCTION ValidDbName(NAME)
Dim bError
'This function will validate a new database name
bError = False
ValidDbName = True
If Len(NAME) > 6 Then
    bError = True
    msgBox "Database names cannot be longer than 6 characters.",,"Error"
ElseIF Not ValidASC(Mid(NAME,1,2)) Then
    bError = True
    msgBox "The first 2 characters of the database name must be an Application System Code",,"Error"
ElseIf Mid(NAME,3,1) <> "B" Then
    bError = True
    msgBox "The 3rd character must to be B",,"Error"
ElseIf Mid(NAME,4,1)<> "P" Then
   If Mid(NAME,4,1)<> "2" then
      If Mid(NAME,4,1)<> "4" then
         bError = True
         msgBox "The fourth character of the database name must to be P, 2 or 4",,"Error"
      End If
   End If
End If
If bError then    
    ValidDbName = False
Else
    ValidDbName = True
End If
END FUNCTION

FUNCTION ValidDbChars(NAME)
DIM aryForbiddenChars(31)
DIM iCount

ValidChar = "True"
	aryForbiddenChars(0)= "!"
	aryForbiddenChars(1)= "@"
	aryForbiddenChars(2)= "#"
	aryForbiddenChars(3)= "$"
	aryForbiddenChars(4)= "%"
	aryForbiddenChars(5)= "^"
